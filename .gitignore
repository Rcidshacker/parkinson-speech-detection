features/*.csv
features/opensmile/*.csv
features/handcrafted/
features/modeling/

# ── Run logs ─────────────────────────────────────────────────────────────────
logs/
stage_1_baseline/logs/
*.log

# ── Evaluation results (re-derive by running the pipeline) ───────────────────
results/
scripts/results/
stage_2_feature_grouping/results/

# ── Generated Excel reports ───────────────────────────────────────────────────
stage_1_baseline/comprehensive_analysis_report*.xlsx
stage_1_baseline/pipeline_results_summary.xlsx
stage_2_feature_grouping/Comprehensive_CMN_Results_Report.xlsx

# -- LaTeX university report template (not project code) --
docs/report_template/
docs/report_template.zip

# ── Claude / IDE settings ─────────────────────────────────────────────────────
.claude/

# ── OS / editor noise ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo
.idea/
.vscode/

# ── Team member repos (nested git repos) ─────────────────────────────────────
stage_1_baseline/team_repos/

