# ── Virtual environment ──────────────────────────────────────────────────────
venv/
.venv/
env/

# ── Python cache ──────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
*.pyd
.Python

# ── Large datasets (audio) — download separately; see README ─────────────────
Dataset/

